{
	"Comment": "CAPSTONE TEST1: Config for Dangling Record Measurement",
	"MaxParallelism": 600,
	"MaxBatchParallelism": 200,
	"MaxQueriesPerSecondPerIP": 50,
	"MaxInflightPerIP": 50,
	"ResolutionTimeoutInSeconds": 3600,
	"MaxQueriesPerResolution": 4000000,
	"WarmUp": true,
	"Retry": {
		"MaxRetries": 5,
		"Backoff": "Values",
		"BackoffValuesInMs": [0, 200, 500, 1000, 3000 ],
	},
	"Input": {
		"Path": "/home/local/slupike/capstone-project/config/capstone_config/subfinder_candidates.csv",
		"CSVColumnIndex": 2,
		"CSVSeparator": ",",
		"Offset": 1,
		"BatchSize": 20,
		"Len": 3145,
		"PSLPath": "/home/local/slupike/capstone-project/config/capstone_config/public_suffix_list.dat"
	},
	"Output": {
		"FileSize": 300,
		"Format": "protobuf",
		"Zip": "zst:fast",
		"Path": "data",
		"ParallelFiles": 1
	},
	"Caching": {
		"InfraDumpFile": "infra.json",
		"InfraTTLInSeconds": 300,
		"Capacity": 3000000
	},
	"UDP": {
		"Disable": false,
		"TimeoutInMs":3000,
		"PoolSize": 80
	},
	"RateLimitingTimeoutInSeconds": 600,
	"TCP": {
		"Disable": false,
		"EphemeralConns": 5000,
		"PoolSize": 3000,
		"IdlePeriodInMs": 30000,
		"UseKeepAlive": true,
		"TimeoutInMs":     2500,
		"DialTimeoutInMs": 3000
	},
	"EnableICMP": false,
	"ICMPOutPath": "icmp.log",

	"AllNameServerIPs": true,
	"TrustAllTLDs": false,
	"TrustedZones": [ ".",  "com.", "net.", "org.", "root-servers.net." ],
	"TrustedZoneNSCount": 2,
	"DoNotScanList": "/home/local/slupike/capstone-project/config/capstone_config/doNotScan.csv",
	"Loglevel": "info",
	"Logfile": "log.log",
	"MaxCNAMEDepth": 64,
	"GatherDNSSEC": true,
	"Modules": [ ],
	"QueryFor": {
		"OnFullNameResolved": [
			{
				"Comment": "Query IPv4 addresses of domain",
				"NameTemplate": "{name}",
				"Type": 1,
				"Class": 1,
			},
			{
				"Comment": "Query IPv6 addresses of domain",
				"NameTemplate": "{name}",
				"Type": 28,
				"Class": 1
			},
		],
		"OnZoneCreated": [
			{
				"Comment": "Query SOA records of zone",
				"NameTemplate": "{zone}",
				"Type": 6,
				"Class": 1,
			},
			{
				"Comment": "Query MX records of zone",
				"NameTemplate": "{zone}",
				"Type": 15,
				"Class": 1,
				"DoNotFollow": false // Resolve mail server names
			},
			{
				"Comment": "Query DNSKEY records of zone",
				"NameTemplate": "{zone}",
				"Type": 48,
				"Class": 1,
			},
			{
				"Comment": "Query DS records of zone.",
				"NameTemplate": "{zone}",
				"Type": 43,
				"Class": 1,
				"AskParent": true
			},
			{
				"Comment": "Query CDNSKEY records of zone",
				"NameTemplate": "{zone}",
				"Type": 60,
				"Class": 1,
				"SkipRoot": true
			},
			{
				"Comment": "Query CDS records of zone.",
				"NameTemplate": "{zone}",
				"Type": 59,
				"Class": 1,
				"SkipRoot": true
			},
			{
				"Comment": "Query bind version records of name servers in zone",
				"NameTemplate": "version.bind.",
				"Type": 16,
				"Class": 3,
				// Many nameservers will terminate a TCP connection if they receive this query.
				// This is interfering with the TCP connection pooling and reuse.
				// Since there should be no truncation, TCP fallback is not necessary anyway.
				"UDPOnly": true,

				// Many nameservers will just not respond. No use in trying too often.
				"MaxRetries": 1,
				"DisableInfraCache": true
			}
		],
	}
}
